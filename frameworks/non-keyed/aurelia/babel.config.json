{
  "assumptions": {
    "setPublicClassFields": true,
    "privateFieldsAsProperties": true,
    "noDocumentAll": true,
    "pureGetters": true,
    "iterableIsArray": true
  },
  "presets": [
    [
      "@babel/preset-env"
    ]
  ],
  "plugins": [
    [
      "@babel/plugin-proposal-decorators",
      {
        "version": "legacy"
      }
    ],
    "@babel/plugin-transform-class-static-block"
  ]
}