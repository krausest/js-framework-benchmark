{
  "name": "results",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "NullVoxPopuli",
  "scripts": {
    "build-prod": "vite build",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "format": "prettier . --write",
    "lint:prettier": "prettier . --check",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "dev": "VITE_NO_JSBF=true vite",
    "start": "concurrently \"npm:start:jsbf\" \"npm:start:watch\" --prefixColors auto",
    "start:jsbf": "./checks.sh start",
    "start:watch": "npm run build-prod; npm exec vite build -- --watch"
  },
  "type": "module",
  "imports": {
    "#config": "./src/config.js",
    "#soon/*": "./src/coming-soon/*",
    "#utils": "./src/utils.js",
    "#routes/*": "./src/routes/*",
    "#components/*": "./src/components/*"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./src/*"
  },
  "js-framework-benchmark": {
    "frameworkVersionFromPackage": "ember-source",
    "frameworkHomeURL": "https://emberjs.com/",
    "language": "JavaScript"
  },
  "packageManager": "npm@8",
  "dependencies": {
    "@glimmer/component": "2.0.0",
    "@glimmer/tracking": "1.1.2",
    "ember-resolver": "13.2.0",
    "ember-source": "6.12.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/runtime": "7.29.2",
    "@ember/optional-features": "3.0.0",
    "@embroider/macros": "1.20.2",
    "@embroider/core": "4.4.7",
    "@embroider/vite": "1.7.2",
    "@rollup/plugin-babel": "7.0.0",
    "babel-plugin-ember-template-compilation": "4.0.0",
    "concurrently": "9.2.1",
    "ember-eslint": "0.6.1",
    "ember-template-lint": "7.9.3",
    "eslint": "10.1.0",
    "prettier": "3.8.1",
    "prettier-plugin-ember-template-tag": "2.1.3",
    "vite": "8.0.3"
  },
  "engines": {
    "node": ">= 18"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  }
}
