<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Astro Nano Stores keyed</title>
  <link href="/css/currentStyle.css" rel="stylesheet" />
</head>
<body>
  <div id="main">
    <div class="container">
      <div class="jumbotron">
        <div class="row">
          <div class="col-md-6">
            <h1>Astro Nano Stores keyed</h1>
          </div>
          <div class="col-md-6">
            <div class="row">
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="run">Create 1,000 rows</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="runlots">Create 10,000 rows</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="add">Append 1,000 rows</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="update">Update every 10th row</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="clear">Clear</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="swaprows">Swap Rows</button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <table class="table table-hover table-striped test-data">
        <tbody id="tbody"></tbody>
      </table>
      <span class="preloadicon glyphicon glyphicon-remove" aria-hidden="true"></span>
    </div>
  </div>
  <template id="trow">
    <tr>
      <td class="col-md-1"></td>
      <td class="col-md-4"><a></a></td>
      <td class="col-md-1"><a><span class="glyphicon glyphicon-remove" aria-hidden="true"></span></a></td>
      <td class="col-md-6"></td>
    </tr>
  </template>
  <script>
    import { atom, map } from 'nanostores';

    const adjectives = [
      'pretty', 'large', 'big', 'small', 'tall', 'short', 'long', 'handsome', 'plain', 'quaint',
      'clean', 'elegant', 'easy', 'angry', 'crazy', 'helpful', 'mushy', 'odd', 'unsightly', 'adorable',
      'important', 'inexpensive', 'cheap', 'expensive', 'fancy',
    ];
    const colours = ['red', 'yellow', 'blue', 'green', 'pink', 'brown', 'purple', 'brown', 'white', 'black', 'orange'];
    const nouns   = ['table', 'chair', 'house', 'bbq', 'desk', 'car', 'pony', 'cookie', 'sandwich', 'burger',
      'pizza', 'mouse', 'keyboard'];

    let nextId = 1;
    let rows   = [];

    const random    = (max) => Math.round(Math.random() * 1000) % max;
    const makeLabel = () =>
      adjectives[random(adjectives.length)] + ' ' +
      colours[random(colours.length)]       + ' ' +
      nouns[random(nouns.length)];

    const buildData = (count) => {
      const data = new Array(count);
      for (let i = 0; i < count; i++) data[i] = { id: nextId++, label: makeLabel() };
      return data;
    };

    const labels     = map({});
    const selectedId = atom(null);
    const structure  = atom(null);

    const setRows = (data) => {
      rows = data;
      const newLabels = {};
      for (const r of data) newLabels[String(r.id)] = r.label;
      labels.set(newLabels);
      structure.set({ type: 'set', ids: data.map(r => r.id) });
    };

    const run = () => {
      selectedId.set(null);
      setRows(buildData(1000));
    };

    const runLots = () => {
      selectedId.set(null);
      setRows(buildData(10000));
    };

    const add = () => {
      const newItems = buildData(1000);
      rows = rows.concat(newItems);
      const newLabels = { ...labels.get() };
      for (const r of newItems) newLabels[String(r.id)] = r.label;
      labels.set(newLabels);
      structure.set({ type: 'append', ids: newItems.map(r => r.id) });
    };

    const update = () => {
      for (let i = 0; i < rows.length; i += 10) {
        const r        = rows[i];
        const newLabel = r.label + ' !!!';
        rows[i]        = { id: r.id, label: newLabel };
        labels.setKey(String(r.id), newLabel);
      }
    };

    const clear = () => {
      selectedId.set(null);
      rows = [];
      labels.set({});
      structure.set({ type: 'clear' });
    };

    const swapRows = () => {
      if (rows.length <= 998) return;
      const id1   = rows[1].id;
      const id998 = rows[998].id;
      const id2   = rows[2].id;
      [rows[1], rows[998]] = [rows[998], rows[1]];
      structure.set({ type: 'swap', id1, id998, id2 });
    };

    const removeRow = (id) => {
      const idx = rows.findIndex(r => r.id === id);
      if (idx < 0) return;
      rows.splice(idx, 1);
      structure.set({ type: 'remove', id });
    };

    const select = (id) => selectedId.set(id);

    const TBODY  = document.getElementById('tbody');
    const TROW   = document.getElementById('trow');
    const rowEls = new Map();

    const makeRow = (id) => {
      const tr = TROW.content.firstElementChild.cloneNode(true);
      tr.dataset.id = id;
      tr.children[0].textContent = id;
      tr.children[1].firstChild.textContent = labels.get()[String(id)] ?? '';
      rowEls.set(id, tr);
      return tr;
    };

    structure.subscribe((cmd) => {
      if (!cmd) return;

      if (cmd.type === 'set') {
        TBODY.textContent = '';
        rowEls.clear();
        const fragment = document.createDocumentFragment();
        for (const id of cmd.ids) fragment.appendChild(makeRow(id));
        TBODY.appendChild(fragment);
        const selId = selectedId.get();
        if (selId != null) { const tr = rowEls.get(selId); if (tr) tr.className = 'danger'; }

      } else if (cmd.type === 'append') {
        const fragment = document.createDocumentFragment();
        for (const id of cmd.ids) fragment.appendChild(makeRow(id));
        TBODY.appendChild(fragment);

      } else if (cmd.type === 'swap') {
        const tr1   = rowEls.get(cmd.id1);
        const tr998 = rowEls.get(cmd.id998);
        const tr2   = rowEls.get(cmd.id2);
        TBODY.insertBefore(tr1, tr998);
        TBODY.insertBefore(tr998, tr2);

      } else if (cmd.type === 'remove') {
        const tr = rowEls.get(cmd.id);
        if (tr) { tr.remove(); rowEls.delete(cmd.id); }

      } else if (cmd.type === 'clear') {
        TBODY.textContent = '';
        rowEls.clear();
      }
    });

    labels.listen((value, oldValue, changedKey) => {
      if (changedKey === undefined) return;
      const tr = rowEls.get(Number(changedKey));
      if (tr) tr.children[1].firstChild.textContent = value[changedKey];
    });

    selectedId.subscribe((id, oldId) => {
      if (oldId != null) { const tr = rowEls.get(oldId); if (tr) tr.className = ''; }
      if (id    != null) { const tr = rowEls.get(id);    if (tr) tr.className = 'danger'; }
    });

    document.getElementById('run').onclick      = run;
    document.getElementById('runlots').onclick  = runLots;
    document.getElementById('add').onclick      = add;
    document.getElementById('update').onclick   = update;
    document.getElementById('clear').onclick    = clear;
    document.getElementById('swaprows').onclick = swapRows;

    TBODY.onclick = (e) => {
      const t = e.target, n = t.tagName, r = t.closest('TR');
      e.stopPropagation();
      if (n === 'SPAN' || (n === 'A' && t.firstElementChild)) removeRow(Number(r.dataset.id));
      else if (n === 'A') select(Number(r.dataset.id));
    };
  </script>
</body>
</html>
