<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Astro Nano Stores keyed</title>
  <link href="/css/currentStyle.css" rel="stylesheet" />
</head>
<body>
  <div id="main">
    <div class="container">
      <div class="jumbotron">
        <div class="row">
          <div class="col-md-6">
            <h1>Astro Nano Stores keyed</h1>
          </div>
          <div class="col-md-6">
            <div class="row">
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="run">Create 1,000 rows</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="runlots">Create 10,000 rows</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="add">Append 1,000 rows</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="update">Update every 10th row</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="clear">Clear</button>
              </div>
              <div class="col-sm-6 smallpad">
                <button type="button" class="btn btn-primary btn-block" id="swaprows">Swap Rows</button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <table class="table table-hover table-striped test-data">
        <tbody id="tbody"></tbody>
      </table>
      <span class="preloadicon glyphicon glyphicon-remove" aria-hidden="true"></span>
    </div>
  </div>
  <template id="trow">
    <tr>
      <td class="col-md-1"></td>
      <td class="col-md-4"><a></a></td>
      <td class="col-md-1"><a><span class="glyphicon glyphicon-remove" aria-hidden="true"></span></a></td>
      <td class="col-md-6"></td>
    </tr>
  </template>
  <script>
    import { atom, map } from 'nanostores';

    // --- data helpers ---

    let nextId = 1;
    const adjectives = [
      'pretty', 'large', 'big', 'small', 'tall', 'short', 'long', 'handsome', 'plain', 'quaint',
      'clean', 'elegant', 'easy', 'angry', 'crazy', 'helpful', 'mushy', 'odd', 'unsightly', 'adorable',
      'important', 'inexpensive', 'cheap', 'expensive', 'fancy',
    ];
    const colours = [
      'red', 'yellow', 'blue', 'green', 'pink', 'brown', 'purple', 'brown', 'white', 'black', 'orange',
    ];
    const nouns = [
      'table', 'chair', 'house', 'bbq', 'desk', 'car', 'pony', 'cookie', 'sandwich', 'burger',
      'pizza', 'mouse', 'keyboard',
    ];

    const _random = (max) => Math.round(Math.random() * 1000) % max;
    const _label = () =>
      adjectives[_random(adjectives.length)] + ' ' +
      colours[_random(colours.length)] + ' ' +
      nouns[_random(nouns.length)];

    function buildData(count) {
      const data = [];
      for (let i = 0; i < count; i++) data.push({ id: nextId++, label: _label() });
      return data;
    }

    // --- stores ---
    // $labels: fine-grained label updates via setKey() → changedKey in listener
    // $selected: targeted class toggle on old and new selected rows
    const $labels   = map({});   // { [id: string]: label }
    const $selected = atom(0);   // currently selected row id (0 = none)

    // --- DOM refs ---
    const TBODY  = document.getElementById('tbody');
    const TROW   = document.getElementById('trow');
    const rowEls = new Map(); // id (number) → TR element
    let   rowsData = [];      // ordered [{id, label}]

    function makeRow(item) {
      const tr = TROW.content.firstElementChild.cloneNode(true);
      tr.$id = item.id;
      tr.children[0].textContent = item.id;
      tr.children[1].firstChild.textContent = item.label;
      return tr;
    }

    function fullRebuild(items) {
      TBODY.textContent = '';
      rowEls.clear();
      const newLabels = {};
      const fragment = document.createDocumentFragment();
      for (const item of items) {
        const tr = makeRow(item);
        rowEls.set(item.id, tr);
        newLabels[String(item.id)] = item.label;
        fragment.appendChild(tr);
      }
      TBODY.appendChild(fragment);
      // Bulk sync stores — changedKey is undefined so listeners skip DOM work
      $labels.set(newLabels);
      $selected.set(0);
    }

    // --- reactive listeners ---

    // Fine-grained: only fires for setKey() calls (changedKey is defined)
    $labels.listen((value, _, changedKey) => {
      if (changedKey === undefined) return; // bulk set() — DOM already up to date
      const tr = rowEls.get(Number(changedKey));
      if (tr) tr.children[1].firstChild.textContent = value[changedKey];
    });

    // Targeted class toggle: only touches two TRs per selection change
    $selected.listen((id, oldId) => {
      if (oldId) { const tr = rowEls.get(oldId); if (tr) tr.className = ''; }
      if (id)    { const tr = rowEls.get(id);    if (tr) tr.className = 'danger'; }
    });

    // --- actions ---

    const run = () => {
      rowsData = buildData(1000);
      fullRebuild(rowsData);
    };

    const runLots = () => {
      rowsData = buildData(10000);
      fullRebuild(rowsData);
    };

    const add = () => {
      const newItems = buildData(1000);
      rowsData = rowsData.concat(newItems);
      const fragment = document.createDocumentFragment();
      const newLabels = {};
      for (const item of newItems) {
        const tr = makeRow(item);
        rowEls.set(item.id, tr);
        newLabels[String(item.id)] = item.label;
        fragment.appendChild(tr);
      }
      TBODY.appendChild(fragment);
      $labels.set({ ...$labels.get(), ...newLabels }); // bulk sync, listener skips
    };

    const update = () => {
      for (let i = 0; i < rowsData.length; i += 10) {
        const item = rowsData[i];
        const newLabel = item.label + ' !!!';
        rowsData[i] = { id: item.id, label: newLabel };
        $labels.setKey(String(item.id), newLabel); // targeted: listener updates one text node
      }
    };

    const clear = () => {
      rowsData = [];
      rowEls.clear();
      TBODY.textContent = '';
      $labels.set({});
      $selected.set(0);
    };

    const swapRows = () => {
      if (rowsData.length <= 998) return;
      const id1   = rowsData[1].id;
      const id998 = rowsData[998].id;
      const r2    = rowEls.get(rowsData[2].id); // reference stays at index 2
      [rowsData[1], rowsData[998]] = [rowsData[998], rowsData[1]];
      const tr1   = rowEls.get(id1);
      const tr998 = rowEls.get(id998);
      // vanillajs-lite swap trick: two insertBefore calls
      TBODY.insertBefore(tr1, tr998);   // tr1 → just before tr998
      TBODY.insertBefore(tr998, r2);    // tr998 → just before original index-2 row
    };

    const removeById = (id) => {
      const idx = rowsData.findIndex((r) => r.id === id);
      if (idx < 0) return;
      rowsData.splice(idx, 1);
      const tr = rowEls.get(id);
      if (tr) tr.remove();
      rowEls.delete(id);
    };

    // --- event binding ---

    document.getElementById('run').onclick = run;
    document.getElementById('runlots').onclick = runLots;
    document.getElementById('add').onclick = add;
    document.getElementById('update').onclick = update;
    document.getElementById('clear').onclick = clear;
    document.getElementById('swaprows').onclick = swapRows;

    TBODY.onclick = (e) => {
      const t = e.target;
      const n = t.tagName;
      const r = t.closest('TR');
      e.stopPropagation();
      if (n === 'SPAN' || (n === 'A' && t.firstElementChild)) {
        removeById(r.$id);
      } else if (n === 'A') {
        $selected.set(r.$id);
      }
    };
  </script>
</body>
</html>
